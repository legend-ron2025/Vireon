{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/admin-panel",  "destination": "/admin-panel.html" },
    { "source": "/admin",        "destination": "/admin-panel.html" },
    { "source": "/dashboard",    "destination": "/admin-panel.html" },
    { "source": "/login",        "destination": "/admin-login.html" },
    { "source": "/shop",         "destination": "/shop.html" },
    { "source": "/cart",         "destination": "/cart.html" },
    { "source": "/wishlist",     "destination": "/wishlist.html" },
    { "source": "/tracking",     "destination": "/tracking.html" },
    { "source": "/about",        "destination": "/about.html" },
    { "source": "/contact",      "destination": "/contact.html" },
    { "source": "/collections",  "destination": "/collections.html" },
    { "source": "/elite",        "destination": "/elite.html" },
    { "source": "/new-arrivals", "destination": "/newarrivals.html" }
  ],
  "headers": [
    {
      "source": "/css/:file",
      "headers": [
        { "key": "Content-Type",  "value": "text/css; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/js/:file",
      "headers": [
        { "key": "Content-Type",  "value": "application/javascript; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
